# Database connection strings for Prisma (Neon)
DATABASE_URL="postgresql://user:password@localhost:5432/studyai_db?sslmode=require&connect_timeout=60"
DIRECT_URL="postgresql://user:password@localhost:5432/studyai_db?sslmode=require&connect_timeout=60"

# Redis Config
REDIS_HOST="localhost"
REDIS_PORT=6379

# Server Port
PORT=4000

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_EXPIRATION="7d"

# CORS Allowed Origins (comma-separated)
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# Gemini AI API Key
GEMINI_API_KEY=""

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# Web Push (VAPID) - Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:your-email@example.com"

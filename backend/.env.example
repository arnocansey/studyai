# Database connection strings for Prisma (Neon)
DATABASE_URL="postgresql://user:password@localhost:5432/studyai_db?sslmode=require&connect_timeout=60"
DIRECT_URL="postgresql://user:password@localhost:5432/studyai_db?sslmode=require&connect_timeout=60"

# Redis Config (BullMQ + Socket.IO adapter)
# Leave unset / REDIS_ENABLED=false unless Redis is actually running.
# Never set REDIS_ENABLED=true without REDIS_URL or REDIS_HOST — that used to hammer localhost:6379.
REDIS_ENABLED=false
# REDIS_HOST="localhost"
# REDIS_PORT=6379
# REDIS_PASSWORD=
# Or use a single URL (Render / managed Redis):
# REDIS_URL="redis://default:password@host:6379"

# Server Port
PORT=4000

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_EXPIRATION="15m"
JWT_REFRESH_DAYS="30"

# Frontend URL (OAuth redirect target)
FRONTEND_URL="http://localhost:3000"

# OAuth (optional — leave blank to hide provider buttons)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/api/v1/auth/google/callback"
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_CALLBACK_URL="http://localhost:4000/api/v1/auth/github/callback"

# CORS Allowed Origins (comma-separated)
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# Gemini AI API Key
GEMINI_API_KEY=""

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# Web Push (VAPID) - Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:your-email@example.com"

# --- Local smoke checklist ---
# 1. docker compose up -d db redis
# 2. cd backend && npx prisma migrate deploy && pnpm start:dev
# 3. Login/register → /dashboard/study-plan → lesson mentor chat → AI review
# 4. Instructor: /dashboard/submissions + /dashboard/students
# 5. Confirm Redis: Socket.IO adapter log + push jobs enqueue when VAPID set
